# ============================================================
# DealStack - ambiente
# Copie este arquivo para `.env` e preencha com seus valores
# ============================================================

# Dashboard / API
ALLOWED_ORIGINS=https://<codespace>-8765.app.github.dev,http://localhost:8765,http://127.0.0.1:8765
API_KEYS=[{"name":"local","key":"<insira sua api key>","scopes":["read","write"]}]
DASHBOARD_API_KEY=<insira sua api key>
RATE_LIMIT_PER_MIN=60
MAX_CONTENT_LENGTH=1048576
SHARED_DATA_DIR=~/.hermes/shared_data

# JWT Auth
JWT_SECRET=<insira um secret aleatorio>
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<insira uma senha forte>

# Meta Ads
META_ACCESS_TOKEN=<insira seu meta access token>
META_API_VERSION=v20.0

# Shopify
SHOPIFY_API_TOKEN=<insira seu shopify api token>

# LLM / IA (opcional)
OPENAI_API_KEY=<insira sua openai api key>

# Stripe (pagamentos)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
