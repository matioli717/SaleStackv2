# ============================================================
# DealStack - Ambiente
# ATENÇÃO: NUNCA comite este arquivo com valores reais!
# Use: cp .env.example .env  e preencha com seus valores
# ============================================================

# Dashboard / API
# Gere uma chave forte com: python3 -c "import secrets; print('ds_' + secrets.token_urlsafe(48))"
API_KEYS=[{"name":"local","key":"<GERAR_CHAVE_FORTE_AQUI>","scopes":["read","write"]}]
DASHBOARD_API_KEY=<MESMA_CHAVE_ACIMA>
ALLOWED_ORIGINS=http://localhost:8765,http://127.0.0.1:8765
RATE_LIMIT_PER_MIN=60
MAX_CONTENT_LENGTH=1048576
SHARED_DATA_DIR=~/.hermes/shared_data

# JWT Auth
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<GERAR_TOKEN_HEX_32>
ADMIN_USERNAME=admin
# Mínimo 12 caracteres, com maiúsculas, minúsculas e números
ADMIN_PASSWORD=<GERAR_SENHA_FORTE>

# Meta Ads
META_ACCESS_TOKEN=
META_API_VERSION=v20.0

# Shopify
SHOPIFY_API_TOKEN=

# LLM / IA (opcional)
OPENAI_API_KEY=

# Stripe (pagamentos) - usar chaves diferentes para test/production
# Stripe test: sk_test_...
# Stripe live: sk_live_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
