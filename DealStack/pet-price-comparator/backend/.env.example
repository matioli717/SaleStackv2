# App
APP_NAME=pet-price-comparator
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pet_comparator
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/pet_comparator

# Redis
REDIS_URL=redis://localhost:6379/0

# Scraping
PLAYWRIGHT_HEADLESS=true
SCRAPER_CONCURRENCY=3
PROXY_URL=

# Partner (WhatsApp / Webhook)
PARTNER_WHATSAPP_NUMBER=5521999999999
PARTNER_WEBHOOK_URL=http://localhost:8000/api/v1/partner/webhook
PARTNER_COMMISSION_PCT=0.08
PARTNER_MIN_MARGIN_PCT=0.05

# External APIs (optional)
SERPAPI_KEY=
AMAZON_PA_API_KEY=
AMAZON_PA_API_SECRET=

# Security
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30