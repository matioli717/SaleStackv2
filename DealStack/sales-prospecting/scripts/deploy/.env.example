# .env.example para Deta Space
# Copie para .env e preencha, OU configure no painel do Deta (Settings > Environment Variables)

# Gera chave: python3 -c "import secrets; print('sk_prod_' + secrets.token_urlsafe(32))"
API_KEYS=*** "sk_prod_..."}"]

# Substitua YOUR_PROJECT_ID pelo ID real do Deta (ex: a1b2c3d4)
ALLOWED_ORIGINS="https://YOUR_PROJECT_ID.deta.app,http://localhost:8765"

RATE_LIMIT_PER_MIN=60
SHARED_DATA_DIR=/mnt/data
MAX_PAYLOAD_SIZE=1048576
SUBPROCESS_TIMEOUT=60